<?php $this->extend('form_row'); ?>

<?php $this->block('field'); ?>
    <fieldset id="ctrl_<?= $this->id ?>"
              class="checkbox_container<?php if ($this->class): ?> <?= $this->class ?><?php endif; ?>"<?php if ($this->help): ?> aria-describedby="help_ctrl_<?= $this->id ?>"<?php endif; ?>>

        <?php if ($this->label): ?>
            <legend>
                <?php if ($this->mandatory): ?>
                    <span class="invisible"><?= $this->mandatoryField ?> </span><?= $this->label ?><span
                            class="mandatory">*</span>
                <?php else: ?>
                    <?= $this->label ?>
                <?php endif; ?>
            </legend>
        <?php endif; ?>

        <?php if ($this->hasErrors()): ?>
            <p class="error"><?= $this->getErrorAsString() ?></p>
        <?php endif; ?>

        <input type="hidden" name="<?= $this->name ?>" value="">

        <?php
            $wrapperElement = $this->option_wrapper_element ?: 'span';
            $wrapperElementAttributes = $this->attrs()->mergeWith($this->wrapperElementAttributes ?: []);
            $checkboxAttributes = $this->attrs()
                    ->set('type', 'checkbox')
                    ->set('name', $this->name)
                    ->set('id', 'opt_' . $this->checkboxOption['id'])
                    ->addClass('checkbox')
                    ->set('value', $this->checkboxOption['value'])
                    ->set('checked', $this->checkboxOption['checked'])
                    ->mergeWith($this->checkboxOption['attributes'])
                    ->mergeWith($this->checkboxAttributes ?: []);
        ?>

        <<?= $wrapperElement ?><?= $wrapperElementAttributes ?>>
            <input<?= $checkboxAttributes ?>>
            <label id="lbl_<?= $this->checkboxOption['id'] ?>" for="opt_<?= $this->checkboxOption['id'] ?>">
                <?php if ($this->mandatory): ?>
                    <span class="invisible"><?= $this->mandatoryField ?> </span><?= $this->checkboxOption['label'] ?>
                    <span class="mandatory">*</span>
                <?php else: ?>
                    <?= $this->checkboxOption['label'] ?>
                <?php endif; ?>
            </label>
        </<?= $wrapperElement ?>>


        <?php if ($this->help): ?>
            <p class="help" id="help_ctrl_<?= $this->id ?>"><?= $this->help ?></p>
        <?php endif; ?>

    </fieldset>
<?php $this->endblock(); ?>